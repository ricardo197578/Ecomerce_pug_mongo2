extends ../layout

block content
  h1= title
  .card.form-wrap
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action=`/comercios${formAction || ""}`)
      .form-group
        label(for="nombre") Nombre
        input#nombre(type="text" name="nombre" placeholder="Nombre del comercio" value=formData.nombre)
      .form-group
        label(for="cuit") CUIT
        input#cuit(type="text" name="cuit" placeholder="20-12345678-9" value=formData.cuit)
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="contacto@comercio.com" value=formData.email)
      .form-group.checkbox-row
        input#activo(type="checkbox" name="activo" checked=formData.activo)
        label(for="activo") Activo
      .actions(style="margin-top:8px")
        button.btn.btn-primary(type="submit")= submitLabel || "Guardar"
        a.btn.btn-secondary(href="/comercios") Cancelar
