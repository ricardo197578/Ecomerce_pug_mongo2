extends ../layout

block content
  .page-header
    h1 Comercios
    a.btn.btn-primary(href="/comercios/new") + Nuevo comercio
  if !items.length
    .empty-state No hay comercios cargados.
  else
    .table-wrap
      table
        thead
          tr
            th Nombre
            th CUIT
            th Email
            th Activo
            th Acciones
        tbody
          each item in items
            tr
              td= item.nombre
              td= item.cuit
              td= item.email
              td
                if item.activo
                  span.badge.badge-green Sí
                else
                  span.badge.badge-red No
              td
                .actions
                  a.btn.btn-sm.btn-secondary(href=`/comercios/${item._id}`) Ver
                  a.btn.btn-sm.btn-secondary(href=`/comercios/${item._id}/edit`) Editar
                  form(method="post" action=`/comercios/${item._id}/delete` style="display:inline")
                    button.btn.btn-sm.btn-danger(type="submit") Eliminar
