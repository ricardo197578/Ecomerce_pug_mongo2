extends ../layout

block content
  .card.form-wrap
    h1= title
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action=`/cuentas-comercio${formAction || ""}`)
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="usuario@comercio.com" value=formData.email required)
      .form-group
        label(for="password") #{isEdit ? "Nueva contrasena (opcional)" : "Contrasena"}
        input#password(type="password" name="password" placeholder=isEdit ? "Dejar vacio para mantener" : "Contrasena" required=!isEdit)
      if authContext && authContext.isCommerceAdmin
        input(type="hidden" name="role" value="COMMERCE_USER")
        .form-group
          label Rol
          input(type="text" value="COMMERCE_USER" disabled)
      else
        .form-group
          label(for="role") Rol
          select(name="role" id="role" required)
            option(value="COMMERCE_ADMIN" selected=formData.role === "COMMERCE_ADMIN") COMMERCE_ADMIN
            option(value="COMMERCE_USER" selected=formData.role === "COMMERCE_USER") COMMERCE_USER
      if authContext && authContext.isCommerceAdmin
        input(type="hidden" name="comercioId" value=formData.comercioId)
        .form-group
          label Comercio
          input(type="text" value=comercios.length ? `${comercios[0].nombre} (${comercios[0].cuit})` : "Comercio asignado" disabled)
      else
        .form-group
          label(for="comercioId") Comercio
          select(name="comercioId" id="comercioId" required)
            option(value="") Seleccionar comercio
            each comercio in comercios
              option(value=comercio._id selected=String(formData.comercioId || "") === String(comercio._id))= `${comercio.nombre} (${comercio.cuit})`
      .form-group
        label(for="tiendaId") Tienda asociada (solo COMMERCE_USER)
        select(name="tiendaId" id="tiendaId")
          option(value="") Sin tienda asociada
          each tienda in tiendas
            option(value=tienda._id selected=String(formData.tiendaId || "") === String(tienda._id))= `${tienda.nombre} - ${tienda.comercioNombre}`
      label.checkbox-row
        input(type="checkbox" name="activo" checked=formData.activo)
        |  Activa
      .actions
        button.btn.btn-primary(type="submit")= submitLabel || "Guardar"
        a.btn.btn-secondary(href="/cuentas-comercio") Volver al listado
