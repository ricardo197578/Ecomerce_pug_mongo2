extends ../layout

block content
  .page-header
    h1 Cuentas de comercio
    if canManageCommerceUsers
      a.btn.btn-primary(href="/cuentas-comercio/new") Nueva cuenta
  if !items.length
    .empty-state No hay cuentas de comercio cargadas.
  else
    .table-wrap
      table
        thead
          tr
            th Email
            th Rol
            th Comercio
            th Tienda
            th Activa
            th Ultimo login
            th Acciones
        tbody
          each item in items
            tr
              td= item.email
              td= item.role
              td= `${item.comercioNombre} (${item.comercioCuit})`
              td= item.tiendaNombre || "-"
              td= item.activo ? "Si" : "No"
              td= item.lastLoginAt ? item.lastLoginAt : "-"
              td
                .actions
                  a.btn.btn-secondary.btn-sm(href=`/cuentas-comercio/${item._id}`) Ver
                  a.btn.btn-secondary.btn-sm(href=`/cuentas-comercio/${item._id}/edit`) Editar
                  form(method="post" action=`/cuentas-comercio/${item._id}/delete` style="display:inline")
                    button.btn.btn-danger.btn-sm(type="submit") Eliminar
