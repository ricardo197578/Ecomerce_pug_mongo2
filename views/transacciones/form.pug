extends ../layout

block content
  h1= title
  .card.form-wrap
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action=`/transacciones${formAction || ""}`)
      .form-group
        label(for="comercioId") Comercio
        select#comercioId(name="comercioId" required)
          option(value="") Seleccionar comercio
          each comercio in comercios
            option(value=comercio._id selected=String(formData.comercioId || "") === String(comercio._id))= `${comercio.nombre} (${comercio.cuit})`
      .form-group
        label(for="tiendaId") Tienda
        select#tiendaId(name="tiendaId" required)
          option(value="") Seleccionar tienda
          each tienda in tiendas
            option(value=tienda._id selected=String(formData.tiendaId || "") === String(tienda._id))= `${tienda.nombre} - ${tienda.comercioNombre}`
      .form-group
        label(for="usuarioId") Usuario
        select#usuarioId(name="usuarioId" required)
          option(value="") Seleccionar usuario
          each usuario in usuarios
            option(value=usuario._id selected=String(formData.usuarioId || "") === String(usuario._id))= `${usuario.nombre} (${usuario.email}) - ${usuario.tiendaNombre}`
      .form-group
        label(for="monto") Monto
        input#monto(type="number" step="0.01" name="monto" placeholder="0.00" value=formData.monto)
      .form-group
        label(for="moneda") Moneda
        input#moneda(type="text" name="moneda" placeholder="ARS / USD" value=formData.moneda)
      .form-group
        label(for="descripcion") Descripción
        input#descripcion(type="text" name="descripcion" placeholder="Descripción opcional" value=formData.descripcion)
      .actions(style="margin-top:8px")
        button.btn.btn-primary(type="submit")= submitLabel || "Guardar"
        a.btn.btn-secondary(href="/transacciones") Cancelar
