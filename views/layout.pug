doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title
    style.
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --brand: #4f46e5;
        --brand-dark: #3730a3;
        --brand-light: #eef2ff;
        --danger: #dc2626;
        --danger-light: #fef2f2;
        --success: #16a34a;
        --success-light: #f0fdf4;
        --warning: #d97706;
        --warning-light: #fffbeb;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-500: #6b7280;
        --gray-700: #374151;
        --gray-900: #111827;
        --radius: 8px;
        --shadow: 0 1px 3px rgba(0,0,0,.1), 0 1px 2px rgba(0,0,0,.06);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -1px rgba(0,0,0,.06);
      }
      body {
        font-family: "Segoe UI", system-ui, -apple-system, sans-serif;
        background: var(--gray-50);
        color: var(--gray-900);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      /* NAV */
      nav {
        background: var(--brand);
        padding: 0 24px;
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        box-shadow: var(--shadow-md);
      }
      nav .nav-brand {
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
        padding: 14px 12px 14px 0;
        margin-right: 8px;
        border-right: 1px solid rgba(255,255,255,.25);
        text-decoration: none;
        letter-spacing: .02em;
      }
      nav a {
        color: rgba(255,255,255,.85);
        text-decoration: none;
        padding: 14px 12px;
        font-size: .875rem;
        font-weight: 500;
        border-radius: 4px;
        transition: background .15s, color .15s;
      }
      nav a:hover { background: rgba(255,255,255,.15); color: #fff; }
      nav form { display: inline-flex; margin-left: auto; }
      nav .nav-spacer { flex: 1; }
      nav .nav-button {
        background: transparent;
        color: rgba(255,255,255,.85);
        padding: 14px 12px;
        font-size: .875rem;
        font-weight: 500;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        transition: background .15s, color .15s;
      }
      nav .nav-button:hover { background: rgba(255,255,255,.15); color: #fff; }
      /* MAIN */
      main {
        flex: 1;
        padding: 32px 24px;
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;
      }
      /* HEADINGS */
      h1 { font-size: 1.6rem; font-weight: 700; color: var(--gray-900); margin-bottom: 20px; }
      h2 { font-size: 1.15rem; font-weight: 600; color: var(--gray-700); margin: 24px 0 10px; }
      /* ALERTS */
      .alert {
        padding: 12px 16px;
        border-radius: var(--radius);
        font-size: .9rem;
        margin-bottom: 16px;
        border-left: 4px solid;
      }
      .alert-error { background: var(--danger-light); border-color: var(--danger); color: var(--danger); }
      /* CARD */
      .card {
        background: #fff;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 24px;
        margin-bottom: 24px;
      }
      /* DETAIL LIST */
      .detail-list { list-style: none; }
      .detail-list li {
        display: flex;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid var(--gray-100);
        font-size: .95rem;
      }
      .detail-list li:last-child { border-bottom: none; }
      .detail-label { font-weight: 600; color: var(--gray-700); min-width: 160px; }
      /* TABLE */
      .table-wrap { overflow-x: auto; border-radius: var(--radius); box-shadow: var(--shadow); }
      table {
        border-collapse: collapse;
        width: 100%;
        background: #fff;
        font-size: .9rem;
      }
      thead { background: var(--gray-50); }
      th {
        padding: 12px 14px;
        text-align: left;
        font-size: .78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--gray-500);
        border-bottom: 2px solid var(--gray-200);
      }
      td {
        padding: 11px 14px;
        border-bottom: 1px solid var(--gray-100);
        color: var(--gray-700);
        vertical-align: middle;
      }
      tbody tr:last-child td { border-bottom: none; }
      tbody tr:hover { background: var(--gray-50); }
      /* BADGES */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 600;
        letter-spacing: .02em;
      }
      .badge-green { background: var(--success-light); color: var(--success); }
      .badge-red { background: var(--danger-light); color: var(--danger); }
      .badge-yellow { background: var(--warning-light); color: var(--warning); }
      .badge-gray { background: var(--gray-100); color: var(--gray-500); }
      .badge-blue { background: var(--brand-light); color: var(--brand); }
      /* BUTTONS */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--radius);
        font-size: .875rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: opacity .15s, box-shadow .15s;
        line-height: 1;
      }
      .btn:hover { opacity: .88; box-shadow: var(--shadow-md); }
      .btn-primary { background: var(--brand); color: #fff; }
      .btn-secondary { background: var(--gray-100); color: var(--gray-700); border: 1px solid var(--gray-200); }
      .btn-danger { background: var(--danger); color: #fff; }
      .btn-sm { padding: 5px 10px; font-size: .8rem; }
      /* FORM */
      .form-wrap { max-width: 560px; }
      .form-group { margin-bottom: 16px; display: flex; flex-direction: column; gap: 6px; }
      label { font-size: .875rem; font-weight: 500; color: var(--gray-700); }
      input[type="text"],
      input[type="email"],
      input[type="number"],
      input[type="password"],
      select {
        padding: 9px 12px;
        border: 1px solid var(--gray-300);
        border-radius: var(--radius);
        font-size: .9rem;
        font-family: inherit;
        background: #fff;
        color: var(--gray-900);
        transition: border-color .15s, box-shadow .15s;
        width: 100%;
      }
      input:focus, select:focus {
        outline: none;
        border-color: var(--brand);
        box-shadow: 0 0 0 3px rgba(79,70,229,.15);
      }
      .checkbox-row { flex-direction: row; align-items: center; gap: 8px; }
      .checkbox-row input[type="checkbox"] { width: auto; }
      /* ACTIONS ROW */
      .actions { display: flex; gap: 8px; align-items: center; }
      .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
      .page-header h1 { margin-bottom: 0; }
      /* STATS */
      .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; margin-bottom: 24px; }
      .stat-card { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); padding: 18px 20px; }
      .stat-label { font-size: .78rem; text-transform: uppercase; letter-spacing: .05em; color: var(--gray-500); font-weight: 600; margin-bottom: 6px; }
      .stat-value { font-size: 1.6rem; font-weight: 700; color: var(--brand); }
      /* EMPTY STATE */
      .empty-state { text-align: center; padding: 48px 24px; color: var(--gray-500); font-size: .95rem; background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); }
      /* BACK LINK */
      .back-link { display: inline-flex; align-items: center; gap: 4px; color: var(--gray-500); text-decoration: none; font-size: .875rem; margin-top: 20px; transition: color .15s; }
      .back-link:hover { color: var(--brand); }
      /* SUMMARY LIST */
      .summary-list { list-style: none; display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 20px; }
      .summary-list li { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); padding: 14px 18px; font-size: .9rem; color: var(--gray-700); }
      .summary-list li strong { display: block; font-size: 1.2rem; color: var(--gray-900); }
      /* FOOTER */
      footer { text-align: center; padding: 16px; font-size: .8rem; color: var(--gray-500); border-top: 1px solid var(--gray-200); background: #fff; margin-top: auto; }
  body
    nav
      a.nav-brand(href="/") ⚡ CodeNova
      a(href="/") Inicio
      if isPlatformAdmin
        a(href="/comercios") Comercios
        a(href="/cuentas-comercio") Cuentas comercio
      if isPlatformAdmin || isCommerceAdmin
        a(href="/tiendas") Tiendas
      if isCommerceAdmin
        a(href="/cuentas-comercio") Cuentas comercio
      if isAuthenticated
        a(href="/usuarios") Usuarios
        a(href="/transacciones") Transacciones
        a(href="/pagos") Pagos
        a(href="/logisticas") Logísticas
      if isPlatformAdmin
        a(href="/suscripciones") Suscripciones
      span.nav-spacer
      if !isAuthenticated
        a(href="/login") Login comercio
        a(href="/platform/login") Login plataforma
      else if isPlatformAdmin
        form(method="post" action="/platform/logout")
          button.nav-button(type="submit") Cerrar sesión plataforma
      else
        form(method="post" action="/logout")
          button.nav-button(type="submit") Cerrar sesión
    main
      block content
    footer
      | © 2025 CodeNova · Panel Operativo
