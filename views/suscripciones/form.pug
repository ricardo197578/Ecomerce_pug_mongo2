extends ../layout

block content
  h1= title
  if errorMessage
    p.error= errorMessage
  form(method="post" action=`/suscripciones${formAction || ""}`)
    label(for="comercioId") Comercio
    select(name="comercioId" id="comercioId" required)
      option(value="") Seleccionar comercio
      each comercio in comercios
        option(value=comercio._id selected=String(formData.comercioId || "") === String(comercio._id))= `${comercio.nombre} (${comercio.cuit})`
    input(type="text" name="planNombre" placeholder="Plan" value=formData.planNombre)
    input(type="number" step="0.01" name="cuotaMensual" placeholder="Cuota" value=formData.cuotaMensual)
    input(type="number" step="0.01" name="comisionPorcentaje" placeholder="Comision %" value=formData.comisionPorcentaje)
    input(type="text" name="moneda" placeholder="Moneda" value=formData.moneda)
    input(type="text" name="estado" placeholder="Estado" value=formData.estado)
    input(type="text" name="fechaInicio" placeholder="YYYY-MM-DD" value=formData.fechaInicio)
    input(type="text" name="fechaRenovacion" placeholder="YYYY-MM-DD" value=formData.fechaRenovacion)
    button(type="submit")= submitLabel || "Guardar"
  p
    a(href="/suscripciones") Volver al listado
