extends ../layout

block content
  .page-header
    h1 Suscripciones
    a.btn.btn-primary(href="/suscripciones/new") + Nueva suscripción
  if !items.length
    .empty-state No hay suscripciones cargadas.
  else
    .table-wrap
      table
        thead
          tr
            th Comercio
            th Plan
            th Cuota
            th Comisión
            th Estado
            th Acciones
        tbody
          each item in items
            tr
              td= item.comercioNombre
              td= item.planNombre
              td= `${item.cuotaMensual} ${item.moneda}`
              td= `${item.comisionPorcentaje}%`
              td
                span.badge.badge-blue= item.estado
              td
                .actions
                  a.btn.btn-sm.btn-secondary(href=`/suscripciones/${item._id}`) Ver
                  a.btn.btn-sm.btn-secondary(href=`/suscripciones/${item._id}/edit`) Editar
                  form(method="post" action=`/suscripciones/${item._id}/delete` style="display:inline")
                    button.btn.btn-sm.btn-danger(type="submit") Eliminar
