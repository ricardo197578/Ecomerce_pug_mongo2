extends ../layout

block content
  .page-header
    h1 Detalle de tienda
    .actions
      a.btn.btn-secondary(href=`/tiendas/${item._id}/edit`) Editar
      a.btn.btn-secondary(href="/tiendas") ← Listado
  .card
    ul.detail-list
      li
        span.detail-label Comercio ID
        span= item.comercioId
      li
        span.detail-label Nombre
        span= item.nombre
      li
        span.detail-label Descripción
        span= item.descripcion || "—"
      li
        span.detail-label Activa
        span
          if item.activa
            span.badge.badge-green Sí
          else
            span.badge.badge-red No
