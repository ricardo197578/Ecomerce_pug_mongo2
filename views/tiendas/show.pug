extends ../layout

block content
  h1 Detalle de tienda
  p
    strong Comercio ID:
    |  #{item.comercioId}
  p
    strong Nombre:
    |  #{item.nombre}
  p
    strong Descripcion:
    |  #{item.descripcion || "-"}
  p
    strong Activa:
    |  #{item.activa ? "Si" : "No"}
  p
    a(href=`/tiendas/${item._id}/edit`) Editar
    |  
    a(href="/tiendas") Volver al listado
