extends ../layout

block content
  .page-header
    h1 Tiendas
    a.btn.btn-primary(href="/tiendas/new") + Nueva tienda
  if !items.length
    .empty-state No hay tiendas cargadas.
  else
    .table-wrap
      table
        thead
          tr
            th Comercio
            th Nombre
            th Descripción
            th Activa
            th Acciones
        tbody
          each item in items
            tr
              td= item.comercioNombre
              td= item.nombre
              td= item.descripcion || "—"
              td
                if item.activa
                  span.badge.badge-green Sí
                else
                  span.badge.badge-red No
              td
                .actions
                  a.btn.btn-sm.btn-secondary(href=`/tiendas/${item._id}`) Ver
                  a.btn.btn-sm.btn-secondary(href=`/tiendas/${item._id}/edit`) Editar
                  form(method="post" action=`/tiendas/${item._id}/delete` style="display:inline")
                    button.btn.btn-sm.btn-danger(type="submit") Eliminar
