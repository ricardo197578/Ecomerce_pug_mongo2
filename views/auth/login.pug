extends ../layout

block content
  .card.form-wrap(style="max-width:400px;margin:40px auto")
    h1(style="text-align:center;margin-bottom:4px") Login comercio
    p(style="text-align:center;color:var(--gray-500);font-size:.85rem;margin-bottom:24px") CodeNova · Panel comercial
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action="/login")
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="usuario@comercio.com" value=formData.email required)
      .form-group
        label(for="password") Contraseña
        input#password(type="password" name="password" placeholder="••••••••" required)
      button.btn.btn-primary(type="submit" style="width:100%;justify-content:center;margin-top:8px") Ingresar
