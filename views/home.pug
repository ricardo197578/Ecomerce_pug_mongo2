extends layout

block content
  if !isAuthenticated
    .card(style="max-width:720px")
      h1 Bienvenido a CodeNova
      p(style="color:var(--gray-700);margin-bottom:16px") Plataforma academica multi-comercio para operar tiendas, usuarios, transacciones, pagos, logistica y reportes.
      p(style="color:var(--gray-500);margin-bottom:20px") Selecciona el acceso correspondiente para continuar.
      .actions
        a.btn.btn-primary(href="/login") Ingresar al panel del comercio
        a.btn.btn-secondary(href="/platform/login") Ingresar al panel de plataforma
  else
    h1 Panel Operativo

    h2 Operación comercial
    .stats-grid
      .stat-card
        .stat-label Comercios
        .stat-value= counts.comercios
      .stat-card
        .stat-label Tiendas
        .stat-value= counts.tiendas
      .stat-card
        .stat-label Usuarios
        .stat-value= counts.usuarios
      .stat-card
        .stat-label Transacciones
        .stat-value= counts.transacciones
      .stat-card
        .stat-label Pagos
        .stat-value= counts.pagos
      .stat-card
        .stat-label Logísticas
        .stat-value= counts.logisticas

    h2 Operaciones
    .actions(style="margin-bottom:24px;flex-wrap:wrap")
      if isCommerceAdmin || isPlatformAdmin
        a.btn.btn-secondary(href="/cuentas-comercio") Ver cuentas
        a.btn.btn-secondary(href="/tiendas") Ver tiendas
      a.btn.btn-secondary(href="/usuarios") Ver usuarios
      a.btn.btn-secondary(href="/transacciones") Ver transacciones
      a.btn.btn-secondary(href="/pagos") Ver pagos
      a.btn.btn-secondary(href="/logisticas") Ver logísticas

    h2 Reportes operativos
    .actions(style="margin-bottom:24px;flex-wrap:wrap")
      a.btn.btn-secondary(href="/reportes/conciliacion") Conciliación
      a.btn.btn-secondary(href="/reportes/hot-sale") Hot Sale

    if isPlatformAdmin
      h2 Gestión de plataforma
      .card(style="max-width:560px")
        .stats-grid(style="grid-template-columns:1fr")
          .stat-card
            .stat-label Suscripciones
            .stat-value= counts.suscripciones
        .actions(style="margin-bottom:16px;flex-wrap:wrap")
          a.btn.btn-secondary(href="/comercios") Administrar comercios
          a.btn.btn-secondary(href="/cuentas-comercio") Cuentas de comercio
          a.btn.btn-secondary(href="/suscripciones") Administrar suscripciones
          a.btn.btn-secondary(href="/reportes/facturacion") Facturación
