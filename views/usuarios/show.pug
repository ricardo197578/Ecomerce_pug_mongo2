extends ../layout

block content
  .page-header
    h1 Detalle de usuario
    .actions
      a.btn.btn-secondary(href=`/usuarios/${item._id}/edit`) Editar
      a.btn.btn-secondary(href="/usuarios") ← Listado
  .card
    ul.detail-list
      li
        span.detail-label Comercio ID
        span= item.comercioId
      li
        span.detail-label Tienda ID
        span= item.tiendaId
      li
        span.detail-label Nombre
        span= item.nombre
      li
        span.detail-label Email
        span= item.email
      li
        span.detail-label Activo
        span
          if item.activo
            span.badge.badge-green Sí
          else
            span.badge.badge-red No
