extends ../layout

block content
  h1= title
  .card.form-wrap
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action=`/usuarios${formAction || ""}`)
      .form-group
        label(for="comercioId") Comercio
        select#comercioId(name="comercioId" required)
          option(value="") Seleccionar comercio
          each comercio in comercios
            option(value=comercio._id selected=String(formData.comercioId || "") === String(comercio._id))= `${comercio.nombre} (${comercio.cuit})`
      .form-group
        label(for="tiendaId") Tienda
        select#tiendaId(name="tiendaId" required)
          option(value="") Seleccionar tienda
          each tienda in tiendas
            option(value=tienda._id selected=String(formData.tiendaId || "") === String(tienda._id))= `${tienda.nombre} - ${tienda.comercioNombre}`
      .form-group
        label(for="nombre") Nombre
        input#nombre(type="text" name="nombre" placeholder="Nombre completo" value=formData.nombre)
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" placeholder="usuario@email.com" value=formData.email)
      .form-group.checkbox-row
        input#activo(type="checkbox" name="activo" checked=formData.activo)
        label(for="activo") Activo
      .actions(style="margin-top:8px")
        button.btn.btn-primary(type="submit")= submitLabel || "Guardar"
        a.btn.btn-secondary(href="/usuarios") Cancelar
