extends ../layout

block content
  .page-header
    h1 Detalle de logística
    .actions
      a.btn.btn-secondary(href=`/logisticas/${item._id}/edit`) Editar
      a.btn.btn-secondary(href="/logisticas") ← Listado
  .card
    ul.detail-list
      li
        span.detail-label Transacción ID
        span= item.transaccionId
      li
        span.detail-label Estado
        - const ec = item.estado === 'ENTREGADA' ? 'badge-green' : item.estado === 'CANCELADA' ? 'badge-red' : item.estado === 'DESPACHADA' ? 'badge-blue' : 'badge-yellow'
        span(class=`badge ${ec}`)= item.estado
      li
        span.detail-label Código seguimiento
        span= item.codigoSeguimiento
      li
        span.detail-label Transportista
        span= item.transportista
      li
        span.detail-label Detalle
        span= item.detalle || "—"
