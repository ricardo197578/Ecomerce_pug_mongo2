extends ../layout

block content
  h1= title
  .card.form-wrap
    if errorMessage
      .alert.alert-error= errorMessage
    form(method="post" action=`/logisticas${formAction || ""}`)
      .form-group
        label(for="transaccionId") Transacción aprobada
        select#transaccionId(name="transaccionId" required)
          option(value="") Seleccionar transacción
          each transaccion in transacciones
            option(value=transaccion._id selected=String(formData.transaccionId || "") === String(transaccion._id))= `${transaccion.monto} ${transaccion.moneda} - ${transaccion.estado}`
      .form-group
        label(for="estado") Estado
        select#estado(name="estado" required)
          option(value="PENDIENTE" selected=formData.estado === "PENDIENTE") PENDIENTE
          option(value="EN_PREPARACION" selected=formData.estado === "EN_PREPARACION") EN_PREPARACION
          option(value="DESPACHADA" selected=formData.estado === "DESPACHADA") DESPACHADA
          option(value="ENTREGADA" selected=formData.estado === "ENTREGADA") ENTREGADA
          option(value="CANCELADA" selected=formData.estado === "CANCELADA") CANCELADA
      .form-group
        label(for="transportista") Transportista
        input#transportista(type="text" name="transportista" placeholder="Nombre del transportista" value=formData.transportista)
      .form-group
        label(for="detalle") Detalle
        input#detalle(type="text" name="detalle" placeholder="Detalle opcional" value=formData.detalle)
      .actions(style="margin-top:8px")
        button.btn.btn-primary(type="submit")= submitLabel || "Guardar"
        a.btn.btn-secondary(href="/logisticas") Cancelar
